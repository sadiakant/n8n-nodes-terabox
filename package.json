{
  "name": "n8n-nodes-terabox",
  "version": "0.1.0",
  "description": "Unofficial n8n community node for TeraBox cloud storage automation. Features QR code login, file management (upload, download, list, search, delete, copy, move, rename), media streaming with M3U8 URLs, share folder access, category & date filtering, and batch operations. Works with session-based authentication for secure, production-ready TeraBox workflow automation.",
  "license": "MIT",
  "homepage": "https://github.com/sadiakant/n8n-nodes-terabox",
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "n8n-node",
    "terabox",
    "terabox-api",
    "terabox-download",
    "terabox-upload",
    "terabox-integration",
    "terabox-automation",
    "terabox-cloud-storage",
    "terabox-file-manager",
    "terabox-media-streaming",
    "terabox-m3u8",
    "terabox-qr-login",
    "terabox-session-auth",
    "cloud-storage",
    "file-management",
    "file-upload",
    "file-download",
    "media-streaming",
    "workflow-automation",
    "automation",
    "nephobox",
    "cloud-sync",
    "backup-automation"
  ],
  "author": {
    "name": "sadiakant",
    "email": "krushnakantsadiya@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sadiakant/n8n-nodes-terabox.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "format": "prettier  --write credentials nodes/Terabox",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "n8n-scan": "npm dlx @n8n/scan-community-package .",
    "test": "n8n-node lint && n8n-node build",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [
      "dist/credentials/TeraboxApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Terabox/Terabox.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}